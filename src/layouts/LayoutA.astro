---
interface Props { title: string; description?: string; }
const { title, description = "Discover your innate resources through presence-based coaching and spinal energetics." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/version-a/" class="nav-logo">Subtle Somatics</a>
        <button class="nav-toggle" aria-label="Toggle menu"><span></span><span></span><span></span></button>
        <div class="nav-links">
          <a href="/version-a/">Home</a>
          <a href="/version-a/#services">Services</a>
          <a href="/version-a/#about">About</a>
          <a href="/version-a/#contact">Contact</a>
          <a href="/version-a/#contact" class="nav-cta">Book a Session</a>
        </div>
      </div>
    </nav>
    <main><slot /></main>
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <h3>Subtle Somatics</h3>
            <p class="tagline">Wholeness in progress</p>
            <p class="footer-purpose">Container schaffen, in denen die nächsten Generationen gut begleitet werden können.</p>
          </div>
          <div class="footer-links">
            <h4>Connect</h4>
            <a href="mailto:connect@subtlesomatics.space">connect@subtlesomatics.space</a>
            <a href="https://www.instagram.com/subtlesomatics/" target="_blank" rel="noopener">Instagram</a>
          </div>
          <div class="footer-newsletter">
            <h4>Stay in Touch</h4>
            <form class="newsletter" action="#"><input type="email" placeholder="Your email" required /><button type="submit">Join</button></form>
          </div>
        </div>
        <div class="footer-bottom"><p>&copy; 2025 Subtle Somatics. All rights reserved.</p></div>
      </div>
    </footer>
    <script>
      const toggle = document.querySelector('.nav-toggle');
      const links = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => { links?.classList.toggle('active'); toggle.classList.toggle('active'); });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --sand: #e8ddd3;
    --sand-light: #f5f0ea;
    --sand-dark: #d4c4b0;
    --sage: #7a8b6f;
    --sage-dark: #5c6b4e;
    --sage-light: #a3b396;
    --terracotta: #c17f59;
    --terracotta-dark: #a06840;
    --warm-brown: #5c4a3a;
    --dark: #2a2520;
    --cream: #faf6f1;
    --text: #3d3428;
    --text-light: #6b5e4f;
    --white: #ffffff;
    --font-heading: 'Playfair Display', Georgia, serif;
    --font-body: 'Lato', 'Segoe UI', sans-serif;
  }
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--font-body); font-weight: 300; color: var(--text); line-height: 1.7; background: var(--cream); -webkit-font-smoothing: antialiased; }
  h1, h2, h3, h4 { font-family: var(--font-heading); font-weight: 400; line-height: 1.2; color: var(--warm-brown); }
  h1 { font-size: clamp(2.5rem, 5vw, 4rem); }
  h2 { font-size: clamp(2rem, 4vw, 3rem); }
  h3 { font-size: clamp(1.4rem, 2.5vw, 1.8rem); }
  p { font-size: 1.05rem; max-width: 65ch; }
  a { color: var(--sage-dark); text-decoration: none; transition: color 0.3s; }
  a:hover { color: var(--terracotta); }
  img { max-width: 100%; height: auto; display: block; }
  .section { padding: 6rem 2rem; max-width: 1100px; margin: 0 auto; }
  .text-center { text-align: center; }
  .btn { display: inline-block; padding: 0.9rem 2.2rem; background: var(--sage-dark); color: var(--cream); font-family: var(--font-body); font-size: 0.85rem; font-weight: 400; letter-spacing: 0.12em; text-transform: uppercase; border: none; border-radius: 2px; cursor: pointer; transition: all 0.3s; }
  .btn:hover { background: var(--terracotta); color: var(--white); }
  .btn-outline { background: transparent; border: 1.5px solid var(--sage-dark); color: var(--sage-dark); }
  .btn-outline:hover { background: var(--sage-dark); color: var(--cream); }

  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(250, 246, 241, 0.95); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(92, 74, 58, 0.08); }
  .nav-inner { max-width: 1100px; margin: 0 auto; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { font-family: var(--font-heading); font-size: 1.4rem; color: var(--warm-brown); letter-spacing: 0.02em; }
  .nav-links { display: flex; gap: 2rem; align-items: center; }
  .nav-links a { font-size: 0.85rem; color: var(--text-light); letter-spacing: 0.06em; text-transform: uppercase; }
  .nav-links a:hover { color: var(--terracotta); }
  .nav-cta { background: var(--sage-dark) !important; color: var(--cream) !important; padding: 0.5rem 1.2rem !important; border-radius: 2px; font-size: 0.8rem !important; }
  .nav-cta:hover { background: var(--terracotta) !important; }
  .nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 5px; }
  .nav-toggle span { width: 22px; height: 1.5px; background: var(--text); transition: all 0.3s; }

  .footer { background: var(--dark); color: var(--sand); padding: 4rem 2rem 2rem; }
  .footer-inner { max-width: 1100px; margin: 0 auto; }
  .footer-top { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 3rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(232, 221, 211, 0.1); }
  .footer h3 { font-size: 1.3rem; color: var(--sand); margin-bottom: 0.5rem; }
  .footer .tagline { font-style: italic; color: var(--sage-light); font-size: 0.9rem; margin-bottom: 0.8rem; }
  .footer-purpose { font-size: 0.85rem; color: var(--sand-dark); font-style: italic; }
  .footer h4 { font-family: var(--font-body); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sage-light); margin-bottom: 1rem; }
  .footer a { color: var(--sand-dark); display: block; margin-bottom: 0.5rem; font-size: 0.9rem; }
  .footer a:hover { color: var(--sand); }
  .newsletter { display: flex; margin-top: 0.5rem; }
  .newsletter input { flex: 1; padding: 0.6rem 1rem; border: 1px solid rgba(232, 221, 211, 0.2); background: rgba(255,255,255,0.05); color: var(--sand); font-family: var(--font-body); font-size: 0.85rem; }
  .newsletter input::placeholder { color: var(--sand-dark); }
  .newsletter button { padding: 0.6rem 1.2rem; background: var(--sage-dark); color: var(--cream); border: none; font-family: var(--font-body); font-size: 0.8rem; letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; }
  .footer-bottom { padding-top: 2rem; font-size: 0.8rem; color: var(--sand-dark); }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .nav-links { display: none; position: absolute; top: 100%; left: 0; right: 0; flex-direction: column; background: rgba(250, 246, 241, 0.98); padding: 1.5rem 2rem; gap: 1.2rem; }
    .nav-links.active { display: flex; }
    .footer-top { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
