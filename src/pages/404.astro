---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — Subtle Somatics" description="The page you are looking for does not exist.">

  <section class="not-found">
    <div class="not-found-inner">
      <h1>404</h1>
      <p class="not-found-heading">This page could not be found.</p>
      <p>Perhaps what you're looking for is waiting to be discovered elsewhere.</p>
      <div class="not-found-links">
        <a href="/" class="btn">Return home</a>
        <a href="/contact" class="btn">Get in touch</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .not-found {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem;
    text-align: center;
  }

  .not-found-inner {
    max-width: 500px;
  }

  .not-found h1 {
    font-size: clamp(4rem, 10vw, 8rem);
    color: var(--color-primary-light);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .not-found-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-meteorite-dark);
    margin-bottom: 1rem;
  }

  .not-found p {
    color: var(--color-gray);
    margin: 0 auto 2rem;
  }

  .not-found-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
