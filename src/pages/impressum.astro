<style>
  .page-hero {
    background: var(--color-meteorite-dark);
    color: var(--color-light);
    padding: 10rem 2rem 6rem;
    text-align: center;
  }
  .page-hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .page-hero h1 { color: var(--color-light); margin-bottom: 1.5rem; }
  .page-hero p { color: rgba(255,255,255,0.8); font-size: 1.15rem; margin: 0 auto; }

  .legal-content {
    max-width: 750px;
    margin: 0 auto;
  }
  .legal-content h2 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: clamp(1.4rem, 3vw, 1.8rem);
  }
  .legal-content h2:first-child { margin-top: 0; }
  .legal-content p { margin-bottom: 1rem; color: var(--color-dark); }
  .legal-content ul {
    list-style: none;
    padding: 0;
    margin-bottom: 1rem;
  }
  .legal-content li {
    padding: 0.3rem 0 0.3rem 1.5rem;
    position: relative;
    color: var(--color-dark);
    font-size: 0.95rem;
  }
  .legal-content li::before {
    content: '\2014';
    position: absolute;
    left: 0;
    color: var(--color-primary-light);
  }
  .legal-notice {
    background: var(--color-cream);
    padding: 2rem;
    border-left: 3px solid var(--color-primary-light);
    margin: 1rem 0 2rem;
  }
  .legal-notice p { font-size: 0.95rem; margin-bottom: 0.8rem; }
  .legal-notice p:last-child { margin-bottom: 0; }
  .legal-ref {
    font-size: 0.85rem !important;
    color: var(--color-gray) !important;
    font-style: italic;
    margin-top: 1rem;
  }
</style>
