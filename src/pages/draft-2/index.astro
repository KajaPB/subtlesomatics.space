---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Subtle Somatics — Presence-Based Coaching & Spinal Energetics" description="Come home to the wisdom already living in your body. Presence-based coaching and spinal energetics with Kaja Possert-Bienzle in Vienna / Styria, Austria.">

  <!-- ═══════════════════════════════════════════════
       HERO — full-screen atmospheric with personal intro
       ═══════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/hero.jpg" alt="" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <div class="hero-grid">
        <div class="hero-text">
          <p class="hero-hi anim-fade">Hi, I'm Kaja.</p>
          <h1 class="anim-fade anim-d1">I help you come home<br/>to the wisdom already<br/>living in your body.</h1>
          <p class="hero-sub anim-fade anim-d2">Through presence-based coaching and spinal energetics, we create the conditions for what is most alive and true in you to emerge — gently, in its own rhythm.</p>
          <div class="hero-btns anim-fade anim-d3">
            <a href="#connect" class="btn btn-glow">Book a free discovery call</a>
            <a href="#offerings" class="btn btn-ghost">How I work</a>
          </div>
        </div>
        <div class="hero-portrait anim-fade anim-d2">
          <div class="portrait-ring"></div>
          <img src="/images/kaja-profile.jpg" alt="Kaja Possert-Bienzle" />
        </div>
      </div>
      <div class="hero-scroll">
        <span>Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       INVITATION — dark poetic section with gold highlights
       ═══════════════════════════════════════════════ -->
  <section class="invitation">
    <div class="invitation-inner">
      <div class="inv-decoration">
        <svg viewBox="0 0 120 120" class="inv-circle"><circle cx="60" cy="60" r="55" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.15"/><circle cx="60" cy="60" r="35" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.1"/></svg>
      </div>
      <p class="inv-pre reveal">I'm inviting you&hellip;</p>
      <div class="inv-lines">
        <p class="reveal"><em>to align</em> <span>with the free-flowing rhythm of your essence</span></p>
        <p class="reveal"><em>to unfold</em> <span>the luminous wonder of deeper aliveness</span></p>
        <p class="reveal"><em>to embody</em> <span>the radiant expression of your unique creativity, love and power</span></p>
      </div>
      <div class="inv-divider reveal"><span></span></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PHILOSOPHY — warm centered question
       ═══════════════════════════════════════════════ -->
  <section class="philosophy">
    <div class="philosophy-inner text-center">
      <p class="section-label reveal">Subtle Somatics</p>
      <h2 class="reveal">What if everything we need<br/>is already here?</h2>
      <p class="philosophy-body reveal">This work is not about fixing or striving. It's about entering the field where what's true begins to reveal itself — in its own rhythm and time.</p>
      <p class="philosophy-body reveal">Within each person lies a vast reservoir of innate resources — strength, courage, compassion, trust, and peace. Not something to be acquired from outside, but something to be uncovered, remembered, and embodied from within.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ABOUT — personal story with image
       ═══════════════════════════════════════════════ -->
  <section class="about" id="about">
    <div class="about-inner">
      <div class="about-img reveal">
        <img src="/images/kaja-profile.jpg" alt="Kaja Possert-Bienzle" />
        <div class="about-img-accent"></div>
      </div>
      <div class="about-text">
        <p class="section-label reveal">About Me</p>
        <h2 class="reveal">Unfolding companion.<br/>Wholeness witnesser.<br/>Integration facilitator.</h2>
        <p class="reveal">I work with the natural intelligence of your body-mind-soul system — where sensations begin to speak, energy reorganises from the depth, and something deeply resonant in you starts moving through silent presence.</p>
        <p class="reveal">My path has been one of deep personal unfolding — through layers of conditioning, protection, and habitual patterns toward something more authentic, more alive, more whole. This lived experience is the foundation of my practice.</p>
        <p class="reveal">I don't guide from theory alone, but from a place of having walked — and continuing to walk — the path of embodied transformation.</p>
        <div class="about-tags reveal">
          <span class="tag">Presence</span>
          <span class="tag">Wholeness</span>
          <span class="tag">Embodiment</span>
          <span class="tag">Trust</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PILLARS — dark ethereal encounter/unfolding/integration
       ═══════════════════════════════════════════════ -->
  <section class="pillars-section" id="offerings">
    <div class="pillars-inner">
      <p class="section-label text-center reveal" style="color:var(--gold)">What I Offer</p>
      <h2 class="text-center reveal" style="color:var(--text-on-dark); margin-bottom:4rem;">Three movements toward wholeness</h2>
      <div class="pillars">
        <div class="pillar reveal">
          <div class="pillar-accent">
            <svg viewBox="0 0 60 60" width="60" height="60" fill="none" stroke="currentColor" stroke-width="0.8"><circle cx="30" cy="30" r="25"/><circle cx="30" cy="30" r="10"/></svg>
          </div>
          <span class="pillar-num">I</span>
          <h3>An encounter</h3>
          <p>Truly getting to know the thoughts, emotions and sensations you have moment to moment.</p>
        </div>
        <div class="pillar-line"></div>
        <div class="pillar reveal">
          <div class="pillar-accent">
            <svg viewBox="0 0 60 60" width="60" height="60" fill="none" stroke="currentColor" stroke-width="0.8"><path d="M30 5 C22 15, 18 22, 18 32 C18 42, 24 55, 30 55 C36 55, 42 42, 42 32 C42 22, 38 15, 30 5Z"/></svg>
          </div>
          <span class="pillar-num">II</span>
          <h3>An unfolding</h3>
          <p>Experiencing your vast inner resourcefulness — in the form of strength, love, presence and more.</p>
        </div>
        <div class="pillar-line"></div>
        <div class="pillar reveal">
          <div class="pillar-accent">
            <svg viewBox="0 0 60 60" width="60" height="60" fill="none" stroke="currentColor" stroke-width="0.8"><path d="M10 30 Q20 12, 30 30 Q40 48, 50 30"/><path d="M10 30 Q20 48, 30 30 Q40 12, 50 30"/></svg>
          </div>
          <span class="pillar-num">III</span>
          <h3>An integration</h3>
          <p>Connecting into deeper coherence, alignment and embodiment of your innate wholeness.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SERVICES — warm section with detailed service cards
       ═══════════════════════════════════════════════ -->
  <section class="services" id="services">
    <div class="services-inner">
      <p class="section-label text-center reveal">Services</p>
      <h2 class="text-center reveal" style="margin-bottom:1rem">Two pathways, one intention</h2>
      <p class="text-center reveal" style="margin:0 auto 3.5rem; color:var(--text-soft)">Both honour the intelligence already present in you.</p>

      <div class="service-card-full reveal">
        <div class="scf-img">
          <img src="/images/subtle-coaching.png" alt="Subtle Coaching" />
          <div class="scf-img-overlay"></div>
        </div>
        <div class="scf-body">
          <span class="scf-badge">Coaching</span>
          <h3>Subtle Coaching</h3>
          <p class="scf-lead">Meet yourself where you are — at the depth where you are vastly resourced to be with life's complexity.</p>
          <p>In presence-based coaching, we work with the alive, moment-to-moment experience of your body-mind-soul system. Through deepening self-contact and gentle inquiry, qualities like courage, tenderness, clarity, and inner strength emerge — not as something new, but as something that was always there, waiting to be met.</p>
          <p class="scf-note"><em>This is not talk therapy. It's an experiential exploration of what is present right now.</em></p>
          <ul class="scf-list">
            <li>Deepen connection to the present moment</li>
            <li>Access innate qualities of strength, love, and presence</li>
            <li>Work with thoughts, emotions, and sensations as doorways</li>
            <li>Cultivate self-contact and inner resourcefulness</li>
          </ul>
          <a href="#connect" class="btn">Book a session</a>
        </div>
      </div>

      <div class="service-card-full reverse reveal">
        <div class="scf-img">
          <img src="/images/spinal-energetics.png" alt="Spinal Energetics" />
          <div class="scf-img-overlay"></div>
        </div>
        <div class="scf-body">
          <span class="scf-badge">Energetics</span>
          <h3>Spinal Energetics</h3>
          <p class="scf-lead">Experience profound mind-body-soul connection — supported by subtle-and-powerful touch and sound.</p>
          <p>Working with the spine as a gateway to your energetic, emotional, and physical layers. Through subtle touch, combined with sound and presence, the body's own intelligence is invited to reorganise, release, and integrate.</p>
          <p>Sessions often involve gentle contact along the spine, allowing stored tension, emotion, and energy to move and transform.</p>
          <p class="scf-note"><em>Many experience deep states of warmth and aliveness as the body finds its way back toward coherence.</em></p>
          <ul class="scf-list">
            <li>Experience profound mind-body-soul integration</li>
            <li>Release stored tension and emotional patterns</li>
            <li>Reconnect with your body's natural intelligence</li>
            <li>Cultivate inner warmth, balance, and aliveness</li>
          </ul>
          <a href="#connect" class="btn">Book a session</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       IMAGE BREAK — atmospheric full-width
       ═══════════════════════════════════════════════ -->
  <section class="img-break">
    <img src="/images/kaja-secondary.png" alt="Kaja — presence and embodiment" />
    <div class="img-break-top"></div>
    <div class="img-break-bottom"></div>
    <div class="img-break-text reveal">
      <p><em>"Container schaffen, in denen die nächsten Generationen gut begleitet werden können."</em></p>
      <p class="img-break-translation">Creating containers in which the next generations can be well accompanied.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       JOURNEY — warm step-by-step process
       ═══════════════════════════════════════════════ -->
  <section class="journey">
    <div class="journey-inner">
      <p class="section-label text-center reveal">Your Journey</p>
      <h2 class="text-center reveal" style="margin-bottom:3.5rem">How we begin</h2>
      <div class="journey-steps">
        <div class="j-step reveal">
          <div class="j-num-wrap">
            <span class="j-num">1</span>
            <div class="j-connector"></div>
          </div>
          <div class="j-content">
            <h3>Discovery call</h3>
            <p>A free conversation to sense into whether this work resonates with you. I'll listen to what's alive for you, and together we'll feel into the right next step. No pressure — just honest connection.</p>
            <span class="j-meta">Free &middot; 20 minutes &middot; Online</span>
          </div>
        </div>
        <div class="j-step reveal">
          <div class="j-num-wrap">
            <span class="j-num">2</span>
            <div class="j-connector"></div>
          </div>
          <div class="j-content">
            <h3>First session</h3>
            <p>We meet you exactly where you are — coaching, spinal energetics, or a blend. Each session is a living exploration, guided by the body's intelligence. The body leads, and I follow.</p>
            <span class="j-meta">60–75 minutes &middot; Online or in person</span>
          </div>
        </div>
        <div class="j-step reveal">
          <div class="j-num-wrap">
            <span class="j-num">3</span>
          </div>
          <div class="j-content">
            <h3>Deepening</h3>
            <p>Transformation unfolds over time. A series of sessions supports the gradual embodiment of your wholeness. Allow yourself space after each session for integration to take root.</p>
            <span class="j-meta">Ongoing &middot; At your rhythm</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       VALUES — dark ethereal section
       ═══════════════════════════════════════════════ -->
  <section class="values">
    <div class="values-inner">
      <p class="section-label text-center reveal" style="color:var(--gold)">What Guides Me</p>
      <h2 class="text-center reveal" style="color:var(--text-on-dark); margin-bottom:3.5rem">Core values</h2>
      <div class="values-grid">
        <div class="val-card reveal">
          <div class="val-icon">
            <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1"><circle cx="24" cy="24" r="20"/><circle cx="24" cy="24" r="3"/></svg>
          </div>
          <h3>Presence</h3>
          <p>Being fully here — with what is. Not fixing, not striving, but meeting the moment with open awareness.</p>
        </div>
        <div class="val-card reveal">
          <div class="val-icon">
            <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1"><circle cx="24" cy="24" r="20"/><circle cx="24" cy="24" r="13"/><circle cx="24" cy="24" r="6"/></svg>
          </div>
          <h3>Wholeness</h3>
          <p>Recognising that you are already whole. Our work is about removing the layers that obscure this truth.</p>
        </div>
        <div class="val-card reveal">
          <div class="val-icon">
            <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1"><path d="M24 4 C18 14, 14 22, 14 30 C14 38, 18 44, 24 44 C30 44, 34 38, 34 30 C34 22, 30 14, 24 4Z"/></svg>
          </div>
          <h3>Embodiment</h3>
          <p>Living from the body's wisdom, not just the mind's understanding. True knowing happens in the tissues, the breath, the bones.</p>
        </div>
        <div class="val-card reveal">
          <div class="val-icon">
            <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1"><path d="M6 24 Q16 8, 24 24 Q32 40, 42 24"/><path d="M6 24 Q16 40, 24 24 Q32 8, 42 24"/></svg>
          </div>
          <h3>Trust</h3>
          <p>Trusting the rhythm of your own unfolding. There is an intelligence at work in you that knows the way.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CONNECT — warm contact section with form
       ═══════════════════════════════════════════════ -->
  <section class="connect" id="connect">
    <div class="connect-inner">
      <div class="connect-left reveal">
        <p class="section-label">Connect</p>
        <h2>Let's talk.</h2>
        <p class="connect-body">Whether you're curious, ready, or somewhere in between — I'd love to hear what's alive for you.</p>
        <p class="connect-body">Begin with a free discovery call — a conversation to sense into whether this work resonates.</p>

        <div class="connect-details">
          <div class="connect-detail">
            <div class="cd-icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <span class="cd-label">Email</span>
              <a href="mailto:connect@subtlesomatics.space">connect@subtlesomatics.space</a>
            </div>
          </div>
          <div class="connect-detail">
            <div class="cd-icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </div>
            <div>
              <span class="cd-label">Instagram</span>
              <a href="https://www.instagram.com/subtlesomatics/" target="_blank" rel="noopener noreferrer">@subtlesomatics</a>
            </div>
          </div>
          <div class="connect-detail">
            <div class="cd-icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="cd-label">Location</span>
              <p>Online & in person — Vienna / Styria, Austria</p>
            </div>
          </div>
        </div>
      </div>
      <div class="connect-right reveal">
        <form class="connect-form" action="#" method="post">
          <div class="form-field">
            <label for="d2-name">Name</label>
            <input type="text" id="d2-name" name="name" placeholder="Your name" />
          </div>
          <div class="form-field">
            <label for="d2-email">Email <span class="req">*</span></label>
            <input type="email" id="d2-email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="form-field">
            <label for="d2-interest">I'm interested in</label>
            <select id="d2-interest" name="interest">
              <option value="">Choose one (optional)</option>
              <option value="coaching">Subtle Coaching</option>
              <option value="spinal">Spinal Energetics</option>
              <option value="both">Both / Not sure yet</option>
              <option value="discovery">Discovery Call</option>
            </select>
          </div>
          <div class="form-field">
            <label for="d2-message">Message <span class="req">*</span></label>
            <textarea id="d2-message" name="message" rows="5" placeholder="What's alive for you right now?" required></textarea>
          </div>
          <button type="submit" class="btn btn-submit">Send message</button>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FINAL — closing dark statement
       ═══════════════════════════════════════════════ -->
  <section class="closing">
    <div class="closing-inner text-center">
      <p class="closing-quote reveal"><em>Wholeness in progress.</em></p>
    </div>
  </section>

</Layout>

<style>
  /* ════════════════════════════════════════════════
     ANIMATIONS
     ════════════════════════════════════════════════ */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.06); opacity: 0.15; }
    100% { transform: scale(1); opacity: 0.3; }
  }

  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  @keyframes line-grow {
    from { height: 0; }
    to { height: 40px; }
  }

  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  .anim-fade {
    animation: fadeUp 1s ease both;
  }
  .anim-d1 { animation-delay: 0.2s; }
  .anim-d2 { animation-delay: 0.4s; }
  .anim-d3 { animation-delay: 0.6s; }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger children */
  .reveal.visible + .reveal.visible { transition-delay: 0.1s; }

  /* ════════════════════════════════════════════════
     SECTION LABEL — reusable gold eyebrow
     ════════════════════════════════════════════════ */
  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  /* ════════════════════════════════════════════════
     HERO
     ════════════════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.35) saturate(0.8);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(45, 27, 105, 0.4) 0%, transparent 60%),
      linear-gradient(to bottom, rgba(17, 11, 36, 0.3) 0%, rgba(17, 11, 36, 0.6) 70%, var(--midnight) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8rem 2rem 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-hi {
    font-family: var(--font-h);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--blush-light);
    margin-bottom: 1.2rem;
  }

  .hero h1 {
    color: var(--white);
    margin-bottom: 1.5rem;
    line-height: 1.15;
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
  }

  .hero-sub {
    color: rgba(237, 232, 224, 0.75);
    margin-bottom: 2.5rem;
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: 500px;
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-glow {
    background: var(--indigo);
    color: var(--cream);
    border: 1px solid rgba(91, 63, 160, 0.5);
    border-radius: 30px;
    box-shadow: 0 0 30px rgba(91, 63, 160, 0.25);
    transition: all 0.4s ease;
  }
  .btn-glow:hover {
    background: var(--violet);
    box-shadow: 0 0 40px rgba(91, 63, 160, 0.4);
    color: var(--white);
    transform: translateY(-2px);
  }

  .btn-ghost {
    background: transparent;
    border: 1px solid rgba(237, 232, 224, 0.25);
    color: var(--text-on-dark);
    border-radius: 30px;
  }
  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(237, 232, 224, 0.4);
    color: var(--white);
  }

  /* Portrait */
  .hero-portrait {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-portrait img {
    width: 340px;
    height: 340px;
    object-fit: cover;
    border-radius: 50% 50% 50% 12%;
    position: relative;
    z-index: 1;
    box-shadow: 0 30px 80px rgba(17, 11, 36, 0.5);
  }

  .portrait-ring {
    position: absolute;
    width: 370px;
    height: 370px;
    border-radius: 50% 50% 50% 12%;
    border: 1px solid rgba(201, 168, 76, 0.2);
    animation: pulse-ring 4s ease-in-out infinite;
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
