---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Subtle Somatics" description="Reach out to explore presence-based coaching and somatic work. Discover your strength, courage, and compassion.">

  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <h1>Reach Out</h1>
      <p>Reach out to explore your innate resources and deepen your mind-body connection through our coaching.</p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section">
    <div class="contact-grid">
      <div class="contact-form-wrapper">
        <h2>Get in Touch</h2>
        <p>I'd love to hear from you. Whether you have questions about the work, want to book a session, or simply feel drawn to connect — send me a message.</p>
        <form class="contact-form" action="#" method="post">
          <div class="form-group">
            <label for="name">Your First Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" />
          </div>
          <div class="form-group">
            <label for="email">Your Email Address <span class="required">*</span></label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="form-group">
            <label for="message">Your Message <span class="required">*</span></label>
            <textarea id="message" name="message" rows="6" placeholder="What's alive for you right now?" required></textarea>
          </div>
          <button type="submit" class="btn btn-filled">Submit Your Inquiry</button>
        </form>
      </div>
      <div class="contact-info">
        <div class="info-card">
          <h3>Contact</h3>
          <p><a href="mailto:connect@subtlesomatics.space">connect@subtlesomatics.space</a></p>
        </div>
        <div class="info-card">
          <h3>Follow</h3>
          <p><a href="https://www.instagram.com/subtlesomatics/" target="_blank" rel="noopener noreferrer">@subtlesomatics</a></p>
        </div>
        <div class="info-card">
          <h3>Sessions</h3>
          <p>Online and in person</p>
          <p class="info-sub">Available Mon–Fri</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section section-cream">
    <h2 class="text-center">Client Feedback</h2>
    <p class="section-subtitle text-center">Hear what our clients say about their transformative experiences.</p>
    <div class="testimonials-grid">
      <div class="testimonial">
        <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote>"The coaching helped me connect deeply with my inner strength and peace."</blockquote>
        <p class="testimonial-name">Sarah L.</p>
        <p class="testimonial-location">New York</p>
      </div>
      <div class="testimonial">
        <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote>"My sessions have brought profound clarity and balance to my life journey."</blockquote>
        <p class="testimonial-name">John D.</p>
        <p class="testimonial-location">Los Angeles</p>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    background: var(--color-meteorite-dark);
    color: var(--color-light);
    padding: 10rem 2rem 6rem;
    text-align: center;
  }

  .page-hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .page-hero h1 {
    color: var(--color-light);
    margin-bottom: 1.5rem;
  }

  .page-hero p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.15rem;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-form-wrapper h2 {
    margin-bottom: 1rem;
  }

  .contact-form-wrapper > p {
    color: var(--color-gray);
    margin-bottom: 2rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-dark);
  }

  .required {
    color: var(--color-accent);
  }

  .form-group input,
  .form-group textarea {
    padding: 0.85rem 1rem;
    border: 1px solid rgba(47, 28, 106, 0.15);
    background: var(--color-warm-bg);
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-dark);
    outline: none;
    transition: border-color 0.3s ease;
    border-radius: 0;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-primary);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-gray-light);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 3.5rem;
  }

  .info-card {
    padding: 1.5rem;
    border-left: 3px solid var(--color-primary-light);
  }

  .info-card h3 {
    font-style: italic;
    color: var(--color-meteorite);
    margin-bottom: 0.5rem;
  }

  .info-card p {
    font-size: 0.95rem;
  }

  .info-sub {
    color: var(--color-gray);
    font-size: 0.85rem !important;
    margin-top: 0.3rem;
  }

  .section-subtitle {
    color: var(--color-gray);
    margin: 0.5rem auto 3rem;
    font-size: 1rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .testimonial {
    background: var(--color-light);
    padding: 2.5rem;
    border-radius: 2px;
    box-shadow: 0 4px 20px rgba(31, 19, 70, 0.06);
  }

  .stars {
    color: #ffcd35;
    font-size: 1.2rem;
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }

  .testimonial blockquote {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--color-dark);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .testimonial-name {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .testimonial-location {
    color: var(--color-gray);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .contact-info {
      margin-top: 0;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
